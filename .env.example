# 🏜️ Desert Rover Studio - API Configuration Template

# 2. Weather Intelligence (Required for Feature 1)
# Get key: https://openweathermap.org/api (Free tier)
OPENWEATHER_API_KEY=your_openweather_key_here

# 3. Mission History (Optional - Cloud Storage)
# Get keys: https://supabase.com/ (Free tier)
# If left blank, system auto-falls back to local SQLite
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# 4. Instant Sharing (Optional - for Feature 6)
# Get key: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_key_here
